upstream edge_cluster {
{% for host in groups['workers'] %}
    server {{ hostvars[host].ansible_host }}:{{ web_port }} max_fails=0;
{% endfor %}
}

server {
    listen 80;
    location / {
        proxy_pass http://edge_cluster;
        proxy_connect_timeout 2s;
        proxy_read_timeout 2s;
    }
}